# =============================================================================
# Artefatos gerados -- nao commitar
# =============================================================================

# Cache de compilacao (auxiliares LaTeX)
build/.cache/

# PDFs finais (versionados por convencao, nao no git)
pdf/*.pdf
!pdf/.gitkeep

# Artefatos LaTeX soltos (caso alguma ferramenta gere fora do cache)
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.lof
*.lot
*.out
*.run.xml
*.synctex.gz
*.synctex(busy)
*.toc

# Editor / SO
.DS_Store
Thumbs.db
*.swp
*~

# Nao ignorar a config compartilhada do VSCode/Cursor
!.vscode/settings.json
!.vscode/extensions.json
